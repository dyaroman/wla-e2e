{
  "private": true,
  "scripts": {
    "codeceptjs:local": "cross-env ENV=local codeceptjs run",
    "codeceptjs:local:headless": "cross-env ENV=local HEADLESS=true codeceptjs run",
    "codeceptjs:dev": "cross-env ENV=dev codeceptjs run",
    "codeceptjs:dev:headless": "cross-env ENV=dev HEADLESS=true codeceptjs run",
    "codeceptjs:prod": "cross-env ENV=prod codeceptjs run",
    "codeceptjs:prod:headless": "cross-env ENV=prod HEADLESS=true codeceptjs run"
  },
  "husky": {
    "hooks": {
      "pre-commit": "./node_modules/.bin/nano-staged"
    }
  },
  "nano-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@codeceptjs/configure": "^1.0.1",
    "codeceptjs": "^3.6.4",
    "cross-env": "^7.0.3",
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "husky": "^4.3.8",
    "nano-staged": "^0.8.0",
    "prettier": "^3.3.2"
  }
}
