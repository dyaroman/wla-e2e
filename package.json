    "@codeceptjs/ui": "^0.4.7",
    "codeceptjs": "^3.3.5",
    "cross-env": "^7.0.3",
    "playwright": "^1.25.0"
  },
  "devDependencies": {
    "@codeceptjs/examples": "^1.2.1",
    "husky": "^4.3.8",
    "nano-staged": "^0.8.0",
    "prettier": "^2.7.1"
  }
}
