{
  "private": true,
  "scripts": {
    "codeceptjs:local": "cross-env NODE_ENV=local codeceptjs run --steps",
    "codeceptjs:local:headless": "cross-env NODE_ENV=local HEADLESS=true codeceptjs run --steps",
    "codeceptjs:local:ui": "cross-env NODE_ENV=local codecept-ui --app",
    "codeceptjs:dev": "cross-env NODE_ENV=dev codeceptjs run --steps",
    "codeceptjs:dev:headless": "cross-env NODE_ENV=dev HEADLESS=true codeceptjs run --steps",
    "codeceptjs:dev:ui": "cross-env NODE_ENV=dev codecept-ui --app",
    "codeceptjs:prod": "cross-env NODE_ENV=prod codeceptjs run --steps",
    "codeceptjs:prod:headless": "cross-env NODE_ENV=prod HEADLESS=true codeceptjs run --steps",
    "codeceptjs:prod:ui": "cross-env NODE_ENV=prod codecept-ui --app",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write --ignore-unknown ."
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@codeceptjs/configure": "^0.8.0",
    "codeceptjs": "^3.3.3",
    "cross-env": "^7.0.3",
    "playwright": "^1.22.0"
  },
  "devDependencies": {
    "@codeceptjs/examples": "^1.2.1",
    "@codeceptjs/ui": "^0.4.6",
    "husky": "^4.3.8",
    "lint-staged": "^12.4.1",
    "prettier": "^2.6.2"
  }
}
